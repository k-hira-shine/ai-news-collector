<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI News 図解版 {{ date }} {{ slot_label }}</title>
<style>
  :root {
    --bg: #f5f6fa;
    --surface: #ffffff;
    --ink: #1a1a2e;
    --ink2: #334155;
    --muted: #64748b;
    --line: #e2e8f0;
    --accent: #6366f1;
    --gold: #f59e0b;
    --silver: #94a3b8;
    --bronze: #b45309;
    --cat-model: #10b981;
    --cat-biz: #f59e0b;
    --cat-reg: #ec4899;
    --cat-research: #6366f1;
    --cat-fund: #f97316;
    --cat-usecase: #3b82f6;
    --cat-default: #64748b;
    --st-new: #16a34a;
    --st-rising: #dc2626;
    --st-sustained: #2563eb;
    --st-fading: #64748b;
    --st-resurfaced: #f59e0b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: var(--bg);
    color: var(--ink);
    font-family:
      "Hiragino Sans", "Hiragino Kaku Gothic ProN",
      "Noto Sans CJK JP", "Noto Sans JP",
      "Yu Gothic", "Yu Gothic UI", "Meiryo",
      -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji",
      sans-serif;
    font-size: 14px;
    line-height: 1.55;
    word-break: keep-all;
    overflow-wrap: break-word;
    line-break: strict;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    font-feature-settings: "palt" 1;
  }
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 28px 24px 32px;
  }
  .nowrap { white-space: nowrap; }

  /* ── ヘッダー ─────────────────────────── */
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px;
    background: var(--ink);
    color: #fff;
    border-radius: 14px;
    margin-bottom: 18px;
  }
  .hero-title {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: 0.02em;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: #cbd5e1;
  }
  .slot-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    font-size: 12px;
  }

  /* ── セクション共通 ─────────────────────── */
  .section {
    background: var(--surface);
    border-radius: 14px;
    padding: 18px 20px;
    margin-bottom: 14px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
  }
  .section-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    font-weight: 800;
    color: var(--ink);
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
  }
  .section-title .num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--ink);
    color: #fff;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  /* ── セクション01: TOP ニュース（メイン・45%） ────────── */
  .top-section { padding: 20px 22px 22px; }
  .top-hero {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 16px;
    align-items: stretch;
    padding: 18px;
    border-radius: 12px;
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border: 1.5px solid var(--gold);
    margin-bottom: 14px;
  }
  .top-hero .medal {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: var(--gold);
    color: #fff;
    border-radius: 12px;
    padding: 10px 6px;
  }
  .top-hero .medal .rank-num { font-size: 32px; font-weight: 900; line-height: 1; }
  .top-hero .medal .rank-label { font-size: 10px; letter-spacing: 0.08em; font-weight: 700; }
  .top-hero .body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }
  .top-hero .title {
    font-size: 17px;
    font-weight: 800;
    color: var(--ink);
    line-height: 1.45;
  }
  .top-hero .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .top-hero .summary {
    font-size: 13.5px;
    color: var(--ink2);
    line-height: 1.6;
  }

  .top-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .top-card {
    display: grid;
    grid-template-columns: 40px minmax(0, 1fr);
    gap: 12px;
    padding: 12px 14px;
    background: #fafbfc;
    border: 1.5px solid var(--line);
    border-left: 4px solid var(--cat-default);
    border-radius: 10px;
  }
  .top-card .rank-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--silver);
    color: #fff;
    font-weight: 800;
    font-size: 14px;
  }
  .top-card .rank-badge.r3 { background: var(--bronze); }
  .top-card.cat-model { border-left-color: var(--cat-model); }
  .top-card.cat-biz { border-left-color: var(--cat-biz); }
  .top-card.cat-reg { border-left-color: var(--cat-reg); }
  .top-card.cat-research { border-left-color: var(--cat-research); }
  .top-card.cat-fund { border-left-color: var(--cat-fund); }
  .top-card.cat-usecase { border-left-color: var(--cat-usecase); }
  .top-card .body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .top-card .title {
    font-size: 13.5px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.45;
  }
  .top-card .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .top-card .summary {
    font-size: 12px;
    color: var(--ink2);
    line-height: 1.55;
  }

  .tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    background: #e2e8f0;
    color: var(--ink2);
    white-space: nowrap;
  }
  .tag.cat-model { background: #d1fae5; color: #047857; }
  .tag.cat-biz { background: #fef3c7; color: #92400e; }
  .tag.cat-reg { background: #fce7f3; color: #be185d; }
  .tag.cat-research { background: #e0e7ff; color: #4338ca; }
  .tag.cat-fund { background: #ffedd5; color: #c2410c; }
  .tag.cat-usecase { background: #dbeafe; color: #1e40af; }
  .tag.src { background: #f1f5f9; color: var(--muted); font-weight: 600; }

  /* ── セクション02: トレンド（補助） ─────────── */
  .trend-box {
    background: var(--ink);
    color: #fff;
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 12px;
  }
  .trend-box p {
    font-size: 13px;
    line-height: 1.6;
    color: #e2e8f0;
  }
  .topic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }
  .topic-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border: 1.5px solid var(--line);
    border-radius: 10px;
    background: #fafbfc;
    min-width: 0;
  }
  .topic-chip .status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 800;
    color: #fff;
    white-space: nowrap;
  }
  .status.st-NEW { background: var(--st-new); }
  .status.st-RISING { background: var(--st-rising); }
  .status.st-SUSTAINED { background: var(--st-sustained); }
  .status.st-FADING { background: var(--st-fading); }
  .status.st-RESURFACED { background: var(--st-resurfaced); }
  .topic-chip .topic-name {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
    flex: 1;
    min-width: 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .topic-chip .streak {
    font-size: 10px;
    color: var(--muted);
    white-space: nowrap;
  }

  /* ── セクション03: カテゴリ分布（補助） ───────── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1.5px solid var(--line);
    border-top: 4px solid var(--cat-default);
    background: #fafbfc;
    min-width: 0;
  }
  .cat-card.cat-model { border-top-color: var(--cat-model); }
  .cat-card.cat-biz { border-top-color: var(--cat-biz); }
  .cat-card.cat-reg { border-top-color: var(--cat-reg); }
  .cat-card.cat-research { border-top-color: var(--cat-research); }
  .cat-card.cat-fund { border-top-color: var(--cat-fund); }
  .cat-card.cat-usecase { border-top-color: var(--cat-usecase); }
  .cat-card .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 6px;
  }
  .cat-card .name { font-size: 13px; font-weight: 800; color: var(--ink); }
  .cat-card .count {
    font-size: 16px;
    font-weight: 900;
    color: var(--accent);
  }
  .cat-card .summary {
    font-size: 11.5px;
    color: var(--ink2);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── セクション04: X トピック（補助） ─────────── */
  .x-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  .x-card {
    padding: 12px 14px;
    border-radius: 10px;
    border: 1.5px solid var(--line);
    background: #fafbfc;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .x-card .head {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .x-card .buzz { font-size: 12px; }
  .x-card .topic {
    font-size: 12.5px;
    font-weight: 800;
    color: var(--ink);
    flex: 1;
    min-width: 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .x-card .desc {
    font-size: 11.5px;
    color: var(--ink2);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── フッタ ─────────────────────────── */
  .footer {
    text-align: center;
    color: var(--muted);
    font-size: 11px;
    margin-top: 14px;
    padding: 8px;
  }
  .footer a { color: var(--accent); text-decoration: none; }

  /* スマホ対応 */
  @media (max-width: 600px) {
    .page { padding: 16px 12px 24px; }
    .top-grid { grid-template-columns: 1fr !important; }
    .trend-grid { grid-template-columns: 1fr !important; }
    .topic-grid { grid-template-columns: 1fr !important; }
    .cat-grid { grid-template-columns: 1fr !important; }
    .x-grid { grid-template-columns: 1fr !important; }
    .hero { padding: 14px 12px; }
    .hero-title { font-size: 1.1rem; }
    .topic-title { font-size: 0.95rem; }
    .rank-num { font-size: 1.4rem !important; }
    .medal { width: 36px !important; height: 36px !important; }
    .nowrap { white-space: normal !important; }
    .tag { font-size: 0.7rem; }
  }
</style>
</head>
<body>
<div class="page">

  <div class="hero">
    <div class="hero-title">🤖 AI News 図解版</div>
    <div class="hero-meta">
      <span>{{ date }}</span>
      <span class="slot-badge">{{ slot_label }}</span>
    </div>
  </div>

  {# ─ 01 TOP ニュース (~45%) ─────────────────── #}
  {% if top_articles %}
  <div class="section top-section">
    <div class="section-title"><span class="num">01</span>今日の TOP ニュース</div>

    {% set first = top_articles[0] %}
    <div class="top-hero">
      <div class="medal">
        <div class="rank-num">1</div>
        <div class="rank-label">TOP</div>
      </div>
      <div class="body">
        <div class="title">{{ first.title }}</div>
        <div class="tags">
          {% if first.category %}<span class="tag {{ first.category_class }}">{{ first.category }}</span>{% endif %}
          {% if first.source_label %}<span class="tag src">{{ first.source_label }}</span>{% endif %}
        </div>
        <div class="summary">{{ first.summary }}</div>
      </div>
    </div>

    {% if top_articles|length > 1 %}
    <div class="top-grid">
      {% for art in top_articles[1:5] %}
      <div class="top-card {{ art.category_class }}">
        <div class="rank-badge {% if art.rank == 3 %}r3{% endif %}">{{ art.rank }}</div>
        <div class="body">
          <div class="title">{{ art.title }}</div>
          <div class="tags">
            {% if art.category %}<span class="tag {{ art.category_class }}">{{ art.category }}</span>{% endif %}
            {% if art.source_label %}<span class="tag src">{{ art.source_label }}</span>{% endif %}
          </div>
          <div class="summary">{{ art.summary }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {# ─ 02 今日のトレンド ─────────────────────── #}
  {% if trend_summary or tracked_topics %}
  <div class="section">
    <div class="section-title"><span class="num">02</span>今日のトレンド</div>
    {% if trend_summary %}
    <div class="trend-box">
      <p>{{ trend_summary }}</p>
    </div>
    {% endif %}
    {% if tracked_topics %}
    <div class="topic-grid">
      {% for t in tracked_topics[:6] %}
      <div class="topic-chip">
        <span class="status st-{{ t.status }}">{{ t.status_icon }} {{ t.status }}</span>
        <span class="topic-name">{{ t.topic }}</span>
        {% if t.streak_days and t.streak_days > 1 %}<span class="streak">{{ t.streak_days }}日目</span>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {# ─ 03 カテゴリ分布 ───────────────────────── #}
  {% if category_summaries %}
  <div class="section">
    <div class="section-title"><span class="num">03</span>カテゴリ分布</div>
    <div class="cat-grid">
      {% for c in category_summaries %}
      <div class="cat-card {{ c.category_class }}">
        <div class="head">
          <span class="name">{{ c.category }}</span>
          <span class="count">{{ c.count }}</span>
        </div>
        <div class="summary">{{ c.summary }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# ─ 04 X で話題 ──────────────────────────── #}
  {% if x_trends %}
  <div class="section">
    <div class="section-title"><span class="num">04</span>X で話題</div>
    <div class="x-grid">
      {% for tr in x_trends[:3] %}
      <div class="x-card">
        <div class="head">
          <span class="buzz">{{ tr.buzz_icon }}</span>
          <span class="topic">{{ tr.topic }}</span>
        </div>
        <div class="desc">{{ tr.description }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="footer">
    Generated {{ generated_at }} · AI News Collector
    {% if dashboard_url %} · <a href="{{ dashboard_url }}">Dashboard</a>{% endif %}
  </div>

</div>
</body>
</html>
